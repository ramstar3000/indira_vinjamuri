---
---

<section id="contact">
  <div class="container">
    <div class="section-header">
      <h2>Get in Touch</h2>
      <p>I'd love to hear from you</p>
    </div>

    <div class="contact-content">
      <div class="contact-info">
        <div class="contact-item">
          <div class="contact-icon">📧</div>
          <div>
            <h3>Email</h3>
            <p><a href="mailto:indira.vinjamuri@merseycare.nhs.uk">indira.vinjamuri@merseycare.nhs.uk</a></p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">🔗</div>
          <div>
            <h3>LinkedIn</h3>
            <p><a href="https://www.linkedin.com/in/indira-vinjamuri-0b629315a" target="_blank" rel="noopener noreferrer">Indira Vinjamuri</a></p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">🐦</div>
          <div>
            <h3>X (Twitter)</h3>
            <p><a href="https://x.com/IVinjamuri" target="_blank" rel="noopener noreferrer">@IVinjamuri</a></p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">🏢</div>
          <div>
            <h3>Office</h3>
            <p>Mersey Care NHS Foundation Trust<br/>North West England</p>
          </div>
        </div>
      </div>

      <div class="contact-form card">
        <h3>Get in Touch</h3>
        <p>Have questions about my campaign? I'd love to hear from you.</p>
        <a href="mailto:indira.vinjamuri@merseycare.nhs.uk?subject=Dean%20Application%20Enquiry" class="btn btn-primary" style="width: 100%; display: inline-block; text-align: center;">
          Send Email
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.75rem;
    align-items: flex-start;
  }

  .contact-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
    border-radius: var(--border-radius);
  }

  .contact-item h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .contact-item p {
    margin-bottom: 0;
    font-size: 0.95rem;
  }

  .placeholder-note {
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-accent);
    padding: 0.5rem 0.75rem;
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    color: var(--color-text-light);
    font-size: 0.85rem;
  }

  .contact-form h3 {
    margin-bottom: 1.5rem;
  }

  .contact-form p {
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .contact-content {
      grid-template-columns: 1fr;
    }
  }
</style>
