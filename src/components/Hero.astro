---
---

<section class="hero" id="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="hero-greeting">Hello, I'm</p>
      <h1>Dr. Indira Vinjamuri</h1>
      <p class="hero-title">Consultant Psychiatrist &bull; Director of Medical Education &bull; Associate Dean, RCPsych</p>
      <p class="hero-desc">
        Dedicated to advancing mental healthcare and shaping the future of psychiatric education across the North West of England.
      </p>
      <div class="hero-actions">
        <a href="#about" class="btn btn-primary">Learn More</a>
        <a href="#contact" class="btn btn-outline">Get in Touch</a>
      </div>
    </div>
    <div class="hero-image">
      <div class="image-placeholder hero-photo">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
          </svg>
          <p>Add your photo here</p>
          <p><small>Replace this with an image tag<br/>pointing to /images/profile.jpg</small></p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 70px;
    background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-greeting {
    font-size: 1.1rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .hero h1 {
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: 1.05rem;
    color: var(--color-primary-light);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    max-width: 500px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-photo {
    width: 100%;
    aspect-ratio: 3 / 4;
    max-width: 380px;
    margin-left: auto;
    border-radius: 12px;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }

    .hero-desc {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-photo {
      max-width: 260px;
      margin: 0 auto;
    }
  }
</style>
