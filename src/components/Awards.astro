---
const awards = [
  {
    title: 'Cochrane Systematic Review — Co-author',
    year: '2013',
    description: 'Co-authored the Cochrane systematic review "Training to recognise the early signs of recurrence in schizophrenia" (Morriss R, Vinjamuri I, Faizal MA, Bolton CA, McCarthy JP). Published in the Cochrane Database of Systematic Reviews, this influential review examined early warning signs interventions for preventing psychotic relapse.',
    link: 'https://pubmed.ncbi.nlm.nih.gov/23450559/',
  },
  {
    title: 'Appointed Chair — General Adult Specialist Advisory Committee (GA-SAC)',
    year: '2019',
    description: 'Elected Chair of the General Adult Specialist Advisory Committee at the Royal College of Psychiatrists, leading national-level policy on training standards and curriculum for general adult psychiatry across the UK.',
    // Note: Year approximate — verify exact appointment date
  },
  {
    title: 'NHS England Education Quality Review — Commendation',
    year: '2023',
    description: 'The NHS England education quality review of Mersey Care NHS Foundation Trust praised the Director of Medical Education as "very visible, approachable and responsive", reflecting the high-quality training environment fostered under Dr Vinjamuri\'s leadership.',
    link: 'https://www.england.nhs.uk/long-read/education-quality-review-mersey-care-nhs-foundation-trust/',
  },
  {
    title: 'Appointed Associate Dean — Royal College of Psychiatrists',
    year: '2024',
    description: 'Appointed Associate Dean for Curricula and Assessment at the Royal College of Psychiatrists, overseeing the development and quality assurance of psychiatric training programmes nationally.',
    // Note: Year approximate — verify exact appointment date
  },
  {
    title: 'Invited Speaker — RCPsych National Conference',
    year: '2025',
    description: 'Invited to present on "Curricula and Assessments" at the Royal College of Psychiatrists\' Clinical and Educational Supervisors Conference, sharing expertise on training standards and assessment frameworks.',
  },
];
---

<section id="awards">
  <div class="container">
    <div class="section-header">
      <h2>Awards & Recognition</h2>
      <p>Acknowledging contributions to psychiatry and medical education</p>
    </div>

    <div class="awards-timeline">
      {awards.map((award) => (
        <div class="award-item">
          <div class="award-marker">
            <div class="award-dot"></div>
          </div>
          <div class="card award-card">
            <span class="award-year">{award.year}</span>
            <h3>{award.title}</h3>
            <p>{award.description}</p>
            {award.link && (
              <a href={award.link} target="_blank" rel="noopener noreferrer" class="award-link">
                View details &rarr;
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .awards-timeline {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
  }

  .awards-timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    opacity: 0.3;
  }

  .award-item {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .award-marker {
    position: relative;
    flex-shrink: 0;
    width: 42px;
    display: flex;
    justify-content: center;
    padding-top: 1.75rem;
  }

  .award-dot {
    width: 14px;
    height: 14px;
    background: var(--color-accent);
    border-radius: 50%;
    border: 3px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-accent);
    z-index: 1;
  }

  .award-card {
    flex: 1;
  }

  .award-year {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .award-card h3 {
    margin-bottom: 0.5rem;
  }

  .award-link {
    display: inline-block;
    margin-top: 0.75rem;
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    transition: color var(--transition);
  }

  .award-link:hover {
    color: var(--color-accent-light);
  }
</style>
