---
const awards = [
  {
    title: 'Award Title Here',
    year: '20XX',
    description: 'Description of the award and its significance.',
  },
  {
    title: 'Award Title Here',
    year: '20XX',
    description: 'Description of the award and its significance.',
  },
  {
    title: 'Award Title Here',
    year: '20XX',
    description: 'Description of the award and its significance.',
  },
];
---

<section id="awards">
  <div class="container">
    <div class="section-header">
      <h2>Awards & Recognition</h2>
      <p>Acknowledging contributions to psychiatry and medical education</p>
    </div>

    <div class="awards-timeline">
      {awards.map((award, index) => (
        <div class="award-item">
          <div class="award-marker">
            <div class="award-dot"></div>
          </div>
          <div class="card award-card">
            <span class="award-year">{award.year}</span>
            <h3>{award.title}</h3>
            <p>{award.description}</p>
            <div class="image-placeholder award-image">
              <div>
                <small>Add award image or certificate</small>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="awards-note">
      <p class="placeholder-note">
        <em>[Update this section with your awards, honours, and recognitions. Edit the awards array in src/components/Awards.astro to add your entries.]</em>
      </p>
    </div>
  </div>
</section>

<style>
  .awards-timeline {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
  }

  .awards-timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    opacity: 0.3;
  }

  .award-item {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .award-marker {
    position: relative;
    flex-shrink: 0;
    width: 42px;
    display: flex;
    justify-content: center;
    padding-top: 1.75rem;
  }

  .award-dot {
    width: 14px;
    height: 14px;
    background: var(--color-accent);
    border-radius: 50%;
    border: 3px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-accent);
    z-index: 1;
  }

  .award-card {
    flex: 1;
  }

  .award-year {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .award-card h3 {
    margin-bottom: 0.5rem;
  }

  .award-image {
    height: 80px;
    margin-top: 1rem;
    font-size: 0.85rem;
  }

  .awards-note {
    max-width: 700px;
    margin: 1rem auto 0;
  }

  .placeholder-note {
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.25rem;
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    color: var(--color-text-light);
  }
</style>
